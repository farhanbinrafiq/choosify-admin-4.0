{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.cjs" },
    { "source": "/api/v1/catalog/:path*", "destination": "/api/health.cjs?catalogPath=:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
