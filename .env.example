# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3001"

# Local dev port (Choosify-Web uses 3000)
PORT=3001

# Application metadata
NODE_ENV=development
APP_NAME="Choosify Admin"
APP_VERSION="0.0.0"

# Comma-separated allowed browser origins for API + Socket.IO CORS
# Local defaults: http://localhost:3000 (storefront), http://localhost:3001 (admin)
# Production example:
# ALLOWED_ORIGINS="https://choosify.bd,https://www.choosify.bd,https://dashboard.choosify.bd"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Product image uploads (Cloudinary)
VITE_CLOUDINARY_CLOUD_NAME="djdyqr8yd"
VITE_CLOUDINARY_UPLOAD_PRESET="choosify_unsigned"
CLOUDINARY_CLOUD_NAME="djdyqr8yd"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Firebase Admin (optional — without this, omni messaging uses in-memory store)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FIRESTORE_DATABASE_ID="ai-studio-c2303f92-945b-405b-9b0b-230b63fef478"

# ── Omni-channel messaging ──────────────────────────────────────────
# mock = inbox works locally, replies stay in Choosify only
# live = deliver via Meta Graph API (requires credentials below)
MESSAGING_MODE=mock

META_VERIFY_TOKEN=choosify_omni_secure_token_abc123
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=

WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Public URL Meta will call for webhooks (set when deployed)
WEBHOOK_PUBLIC_URL=

# ── Catalog API (CMS → storefront sync) ─────────────────────────────
# false = in-memory catalog (resets on server restart)
# true = persist to Firestore (requires Firebase Admin credentials above)
CATALOG_USE_FIRESTORE=false

# Operations API persistence (orders, reviews, leads, coupons, shipments, flags)
OPERATIONS_USE_FIRESTORE=false

# Auth: mock = role picker fallback; live = Firebase email/password + /auth/me role lookup
VITE_AUTH_MODE=mock
ALLOW_DEV_LOGIN=true

# Admin CMS catalog API base (used by admin UI)
VITE_API_BASE_URL="/api/v1"

# ── Security hardening (ES-005) ─────────────────────────────────────
# Rate limiting window (milliseconds) and per-policy max requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_HEALTH_MAX=120
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PUBLIC_MAX=300
RATE_LIMIT_CATALOG_READ_MAX=600
RATE_LIMIT_SEARCH_MAX=120
RATE_LIMIT_MESSAGING_MAX=100
RATE_LIMIT_ADMIN_MAX=200

# Request body size limits (supports express bytes format, e.g. 1mb, 256kb)
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
RAW_BODY_LIMIT=256kb

# Base64 image upload max decoded size (bytes)
UPLOAD_MAX_BYTES=5242880

# Abuse protection thresholds (in-memory; no persistence)
ABUSE_FAILED_AUTH_WINDOW_MS=900000
ABUSE_FAILED_AUTH_THRESHOLD=20
ABUSE_SUSPICIOUS_WINDOW_MS=900000
ABUSE_SUSPICIOUS_THRESHOLD=200
