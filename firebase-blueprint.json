{
  "entities": {
    "User": {
      "title": "User",
      "description": "Standard user profile for Choosify",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["GUEST", "USER", "SELLER", "CREATOR", "MODERATOR", "CONTENT_ADMIN", "FINANCE_ADMIN", "SUPER_ADMIN"] },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "BANNED"] }
      },
      "required": ["userId", "email", "role"]
    },
    "Seller": {
      "title": "Seller",
      "description": "Seller business profile",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "category": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "documents": { "type": "array" },
        "totalProducts": { "type": "number" },
        "totalRevenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "userId", "businessName"]
    },
    "Creator": {
      "title": "Creator",
      "description": "Recommendation expert profile",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "userId": { "type": "string" },
        "bio": { "type": "string" },
        "socialLinks": { "type": "array" },
        "affiliateEarnings": { "type": "number" },
        "totalViews": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Product listing",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "sellerId": { "type": "string" },
        "brandId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "status": { "type": "string", "enum": ["PENDING", "LIVE", "FLAGGED", "REMOVED"] },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deal": {
      "title": "Deal",
      "description": "Promotional offer",
      "type": "object",
      "properties": {
        "dealId": { "type": "string" },
        "sellerId": { "type": "string" },
        "name": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "LIVE", "EXPIRED"] },
        "clicks": { "type": "number" }
      }
    },
    "Recommendation": {
      "title": "Recommendation",
      "description": "Creator recommendation article",
      "type": "object",
      "properties": {
        "recommendationId": { "type": "string" },
        "creatorId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "PUBLISHED", "FLAGGED"] },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "User review of a product",
      "type": "object",
      "properties": {
        "reviewId": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["PUBLISHED", "FLAGGED", "DELETED"] },
        "reports": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Customer support or inquiry message",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "senderId": { "type": "string" },
        "recipientId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["USER", "SELLER"] },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["UNREAD", "READ", "RESPONDED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "replies": { "type": "array" }
      },
      "required": ["senderId", "content", "status"]
    },
    "CMSData": {
      "title": "CMS Data",
      "description": "Dynamic configuration for logos, navigation, and social links",
      "type": "object",
      "properties": {
        "logos": {
          "type": "object",
          "properties": {
            "header": { "type": "string" },
            "footer": { "type": "string" }
          }
        },
        "navigation": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "path": { "type": "string" },
              "order": { "type": "number" }
            }
          }
        },
        "socialLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "platform": { "type": "string", "enum": ["Facebook", "Instagram", "YouTube", "TikTok", "WhatsApp"] },
              "url": { "type": "string" },
              "isVisible": { "type": "boolean" }
            }
          }
        }
      }
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Generic schema for sponsored ads and featured content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["AD", "POST", "PRODUCT", "BRAND", "DEAL", "RECOMMENDATION"] },
        "targetId": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "SCHEDULED", "EXPIRED"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "placement": { "type": "string" },
        "targeting": { "type": "array" },
        "priority": { "type": "number" },
        "analytics": {
          "type": "object",
          "properties": {
            "impressions": { "type": "number" },
            "clicks": { "type": "number" },
            "ctr": { "type": "number" }
          }
        }
      },
      "required": ["type", "status"]
    },
    "PromotionRequest": {
      "title": "PromotionRequest",
      "description": "Seller or Creator sponsored promotion placement request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterRole": { "type": "string", "enum": ["seller", "creator"] },
        "requesterName": { "type": "string" },
        "contentType": { "type": "string" },
        "contentId": { "type": "string" },
        "contentName": { "type": "string" },
        "requestedPromotionType": { "type": "string" },
        "featurePriority": { "type": "string" },
        "duration": { "type": "number" },
        "placementRequest": { "type": "string" },
        "approvalStatus": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requesterId", "contentId", "approvalStatus"]
    },
    "OmniConversation": {
      "title": "OmniConversation",
      "description": "Omnichannel unified conversation thread",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "platform": { "type": "string", "enum": ["whatsapp", "messenger", "instagram", "platform"] },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "lastMessage": { "type": "string" },
        "assignedAgent": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "pending", "resolved"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "platform", "senderName", "status", "updatedAt"]
    },
    "OmniMessage": {
      "title": "OmniMessage",
      "description": "Unified omnichannel message object",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platform": { "type": "string", "enum": ["whatsapp", "messenger", "instagram", "platform"] },
        "platformMessageId": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "content": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["text", "image", "file"] },
            "body": { "type": "string" },
            "mediaUrl": { "type": "string" }
          },
          "required": ["type", "body"]
        },
        "direction": { "type": "string", "enum": ["inbound", "outbound"] },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "assignedAgent": { "type": "string" },
        "conversationStatus": { "type": "string", "enum": ["open", "pending", "resolved"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "platform", "platformMessageId", "conversationId", "senderId", "senderName", "content", "direction", "status", "timestamp"]
    },
    "OmniAgent": {
      "title": "OmniAgent",
      "description": "Omnichannel Support Agent profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "assignedConversations": { "type": "array" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["id", "name", "email", "role", "assignedConversations", "status"]
    },
    "OmniCustomer": {
      "title": "OmniCustomer",
      "description": "Omnichannel customer master registry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" },
        "platformIds": {
          "type": "object",
          "properties": {
            "whatsapp": { "type": "string" },
            "messenger": { "type": "string" },
            "instagram": { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "platformIds"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "LMS Shipment consignment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "sellerId": { "type": "string" },
        "customerId": { "type": "string" },
        "status": { "type": "string" },
        "courier": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "trackingNumber": { "type": "string" },
        "waybillNumber": { "type": "string" },
        "weight": { "type": "number" },
        "codAmount": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "totalCharge": { "type": "number" },
        "trackingEvents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string" },
              "status": { "type": "string" },
              "location": { "type": "string" },
              "remarks": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "orderId", "sellerId", "status", "trackingNumber"]
    },
    "CourierProviderConfig": {
      "title": "CourierProviderConfig",
      "description": "Courier configuration and API keys",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "apiKey": { "type": "string" },
        "apiSecret": { "type": "string" },
        "webhookSecret": { "type": "string" },
        "apiUrl": { "type": "string" },
        "enabled": { "type": "boolean" },
        "sandbox": { "type": "boolean" },
        "healthStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name", "enabled"]
    },
    "ShippingRule": {
      "title": "ShippingRule",
      "description": "Merchant automation rule for logistics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "priority": { "type": "number" },
        "conditions": { "type": "object" },
        "action": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "name", "enabled", "priority", "conditions", "action"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "Merchant warehouse inventory storage and dispatch center",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "object" },
        "contactPerson": { "type": "object" },
        "isDefault": { "type": "boolean" },
        "couriers": { "type": "array" },
        "preferredCourier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "name", "isDefault"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Combined User profile and private data"
    },
    "/sellers/{sellerId}": {
      "schema": "Seller",
      "description": "Seller profiles"
    },
    "/creators/{creatorId}": {
      "schema": "Creator",
      "description": "Creator profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product directory"
    },
    "/deals/{dealId}": {
      "schema": "Deal",
      "description": "Active promotional deals"
    },
    "/recommendations/{recommendationId}": {
      "schema": "Recommendation",
      "description": "Curated recommendation articles"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Support inquiries and responses"
    },
    "/settings/{settingId}": {
      "schema": "CMSData",
      "description": "Global application settings and CMS content"
    },
    "/promotions/{promotionId}": {
      "schema": "Promotion",
      "description": "Sponsored ads and featured content"
    },
    "/promotion_requests/{requestId}": {
      "schema": "PromotionRequest",
      "description": "Centralized sponsored requests from merchants/creators"
    },
    "/omni_conversations/{conversationId}": {
      "schema": "OmniConversation",
      "description": "Unified omnichannel conversation threads"
    },
    "/omni_messages/{messageId}": {
      "schema": "OmniMessage",
      "description": "Unified omnichannel messages"
    },
    "/omni_agents/{agentId}": {
      "schema": "OmniAgent",
      "description": "Support team agent profiles"
    },
    "/omni_customers/{customerId}": {
      "schema": "OmniCustomer",
      "description": "Unified customer master registry"
    },
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "LMS Consignments"
    },
    "/courier_configs/{configId}": {
      "schema": "CourierProviderConfig",
      "description": "Courier Integrations Settings"
    },
    "/shipping_rules/{ruleId}": {
      "schema": "ShippingRule",
      "description": "Logistics Automation Rules"
    },
    "/warehouses/{warehouseId}": {
      "schema": "Warehouse",
      "description": "Merchant Warehouses Locations"
    }
  }
}
